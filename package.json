{
  "name": "multiai-cli",
  "version": "0.1.0",
  "description": "One CLI shell that drives Claude Code and Codex side by side, reusing their own auth. Streams Claude token-by-token and keeps native multi-turn sessions for both.",
  "type": "module",
  "bin": {
    "multiai": "dist/cli.js"
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "start": "node src/cli.ts",
    "build": "tsc",
    "prepare": "tsc"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "cli",
    "claude",
    "codex",
    "claude-code",
    "ai",
    "llm",
    "repl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Freedom202601/MultiAI.git"
  },
